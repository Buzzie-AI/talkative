{
  "name": "talkative",
  "version": "1.0.0",
  "main": "dist/index.js",
  "bin": {
    "talkative": "bin/talkative.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "npx tsx test/role-check.ts",
    "test:logout": "npx tsx test/logout.test.ts",
    "node-worker": "tsx channel/node.ts",
    "talk": "tsx channel/node.ts",
    "build:plugin": "esbuild channel/node.ts --bundle --platform=node --target=node18 --format=cjs --outfile=plugin/channel/node.cjs --external:bufferutil --external:utf-8-validate && cp channel/instructions.md plugin/channel/instructions.md"
  },
  "author": "",
  "license": "ISC",
  "description": "Two Claude CLI instances talking to each other",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "blessed": "^0.1.81",
    "commander": "^12.0.0",
    "node-pty": "^1.1.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
